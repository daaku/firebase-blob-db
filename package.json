{
  "name": "@daaku/firebase-blob-db",
  "author": "Naitik Shah <n@daaku.org>",
  "version": "2.2.0",
  "description": "Resilient uploading of blobs to Firebase Storage.",
  "repository": "git@github.com:daaku/firebase-blob-db",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": { "import": "./dist/src/index.js", "types": "./dist/src/index.d.ts" }
  },
  "prettier": {
    "arrowParens": "avoid",
    "semi": false,
    "singleQuote": true,
    "trailingComma": "all"
  },
  "scripts": {
    "test": "vite build && TIMEOUT=30000 qunit-puppeteer",
    "prepare": "tsc",
    "dev": "vite"
  },
  "keywords": ["firebase", "api"],
  "devDependencies": {
    "@daaku/firebase-auth": "^2.7.0",
    "@daaku/qunit-puppeteer": "^4.1.0",
    "@types/qunit": "^2.19.13",
    "nanoid": "^5.1.7",
    "qunit": "^2.25.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  },
  "dependencies": { "@daaku/firebase-storage": "^2.2.0", "idb": "^8.0.3" }
}
